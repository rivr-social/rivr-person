# Core app
NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1
PORT=3000
HOSTNAME=0.0.0.0

# Auth
NEXTAUTH_URL=https://rivr.example.com
NEXT_PUBLIC_BASE_URL=https://rivr.example.com
AUTH_SECRET=replace-with-a-long-random-secret

# Database
DATABASE_URL=postgresql://rivr:replace-me@postgres:5432/rivr_person

# Person instance identity
INSTANCE_TYPE=person
INSTANCE_ID=replace-with-node-uuid
INSTANCE_SLUG=person
INSTANCE_NAME=Rivr Person
PRIMARY_AGENT_ID=replace-with-person-agent-uuid
REGISTRY_URL=https://b.rivr.social/api/federation/registry
NEXT_PUBLIC_REGISTRY_URL=https://b.rivr.social/api/federation/registry
# Global instance URL — sovereign logo links here. Derived from REGISTRY_URL if omitted.
NEXT_PUBLIC_GLOBAL_URL=https://app.rivr.social
NODE_ADMIN_KEY=replace-with-admin-key

# Autobot / MCP — enables autonomous AI agent access to this instance.
# Generate a strong random token (e.g. openssl rand -hex 32).
# The autobot authenticates via Authorization: Bearer <token> on POST /api/mcp.
# Discovery endpoint: GET /.well-known/mcp
# Control plane UI: /autobot
AIAGENT_MCP_TOKEN=replace-with-a-long-random-token

# Public host/domain helpers
NEXT_PUBLIC_DOMAIN=example.com
NEXT_PUBLIC_APP_URL=https://rivr.example.com
ASSET_PUBLIC_BASE_URL=https://s3.example.com
NEXT_PUBLIC_MINIO_URL=https://s3.example.com

# Object storage
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=replace-me
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=replace-me
MINIO_BUCKET=rivr-uploads
MINIO_BUCKET_UPLOADS=rivr-uploads
MINIO_BUCKET_AVATARS=rivr-avatars
MINIO_BUCKET_EXPORTS=rivr-exports

# Optional integrations
REDIS_URL=redis://redis:6379
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DROPBOX_CLIENT_ID=
DROPBOX_CLIENT_SECRET=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_BOT_TOKEN=
WHATSAPP_APP_ID=
WHATSAPP_APP_SECRET=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
TELLER_APPLICATION_ID=
TELLER_ENVIRONMENT=sandbox
TELLER_CERT_PEM=
TELLER_KEY_PEM=
TELLER_SIGNING_PUBLIC_KEY=
TELLER_WEBHOOK_SECRET=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com
SMTP_SECURE=false
SMTP_TLS_REJECT_UNAUTHORIZED=true
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
MAPBOX_TOKEN=
NEXT_PUBLIC_MAPBOX_TOKEN=

# Optional app release metadata / update surface
APP_RELEASE_CHANNEL=stable
APP_UPSTREAM_REPO=rivr-social/rivr-person
APP_LATEST_VERSION=
APP_LATEST_URL=
APP_CHANGELOG_URL=
APP_BUILD_TIME=
GIT_COMMIT_SHA=

# Google AI / Gemini (usage-limit fallback for builder & autobot)
GOOGLE_AI_API_KEY=

# Audio transcription
# Option A: Self-hosted WhisperX (see docs/whisperx/README.md for setup)
#   Point to the WhisperX FastAPI service. When using Docker Lab compose chain,
#   use the internal service name: http://whisperx:9200/
#   For an external host: http://<host>:9200/
WHISPER_TRANSCRIBE_URL=
WHISPER_TRANSCRIBE_API_KEY=
WHISPER_TRANSCRIBE_MODEL=base
# Option B: OpenAI API (fallback when WHISPER_TRANSCRIBE_URL is not set)
OPENAI_API_KEY=
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe

# Agent HQ — writable directory for agent-hq session/workspace metadata.
# Defaults to $HOME/.agent-hq when process.cwd() is read-only (Docker).
# Container-friendly defaults:
# AGENT_HQ_DATA_DIR=/workspace/.agent-hq
# AGENT_HQ_WORKSPACE_ROOT=
# AGENT_HQ_APP_WORKSPACE_ROOT=/workspace/apps

# Autobot Knowledge Graph — connects to the Autobot token-server KG API.
# Required for persona-scoped knowledge graphs, doc ingestion, and KG chat.
AUTOBOT_KG_URL=http://openclaw-web:3000
AUTOBOT_KG_TOKEN=replace-with-kg-api-token

# OpenClaw chat proxy
OPENCLAW_URL=https://ai.camalot.me

# (Legacy location — see Autobot / MCP section above for the primary config.
#  This line is kept for backward compatibility with older compose files.)
# AIAGENT_MCP_TOKEN=

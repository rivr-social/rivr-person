# ==============================================================
# rivr-person Sovereign Sidecar Stack — Environment Configuration
# ==============================================================
#
# Copy this file to .env and fill in the required values.
#
#   cp .env.sidecar.example .env
#
# Required values are marked with "REQUIRED". Everything else
# has sensible defaults or is optional.
#
# Generate secrets with:
#   openssl rand -hex 32
#
# ==============================================================


# ==============================================================
# DOMAIN & TLS
# ==============================================================

# REQUIRED — Your domain name. Traefik routes:
#   ${DOMAIN}        -> rivr-person (main app)
#   ai.${DOMAIN}     -> openclaw-gateway (agent API)
#   chat.${DOMAIN}   -> openclaw-web (chat UI)
DOMAIN=rivr.example.com

# REQUIRED — Email for Let's Encrypt certificate registration.
ACME_EMAIL=you@example.com

# Traefik log level (DEBUG, INFO, WARN, ERROR)
TRAEFIK_LOG_LEVEL=WARN


# ==============================================================
# POSTGRESQL
# ==============================================================

# Superuser credentials for the PostgreSQL instance.
# The init scripts create separate databases and users for
# the rivr app and the knowledge graph.
POSTGRES_USER=postgres
# REQUIRED — Choose a strong password for the PostgreSQL superuser.
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_DB=postgres

# rivr-person application database credentials.
# These are created by the init script on first start.
RIVR_DB_USER=rivr
# REQUIRED — Password for the rivr app database user.
RIVR_DB_PASSWORD=replace-with-strong-password
RIVR_DB_NAME=rivr_person

# Knowledge graph database credentials (used by OpenClaw extension).
# Created by the KG init script on first start.
KG_DB_USER=cartoon
# REQUIRED — Password for the knowledge graph database user.
KG_DB_PASSWORD=replace-with-strong-password
KG_DB_NAME=cartoon_kg

# PostgreSQL tuning (defaults are reasonable for 4GB RAM hosts)
POSTGRES_SHARED_BUFFERS=256MB
POSTGRES_EFFECTIVE_CACHE=768MB
POSTGRES_WORK_MEM=4MB
POSTGRES_MAX_CONNECTIONS=100
POSTGRES_MEMORY_LIMIT=1G


# ==============================================================
# RIVR-PERSON (Next.js App)
# ==============================================================

# REQUIRED — Random secret for NextAuth session signing.
# Generate with: openssl rand -hex 32
AUTH_SECRET=replace-with-a-long-random-secret

# REQUIRED — Public URL where this instance will be accessible.
# Must match your DOMAIN above with the correct scheme.
NEXTAUTH_URL=https://rivr.example.com
NEXT_PUBLIC_BASE_URL=https://rivr.example.com
NEXT_PUBLIC_APP_URL=https://rivr.example.com
NEXT_PUBLIC_DOMAIN=example.com

# The DATABASE_URL is constructed automatically in docker-compose.sidecar.yml
# from RIVR_DB_USER, RIVR_DB_PASSWORD, and RIVR_DB_NAME above.
# Only set this if you need to override the automatic connection string.
# DATABASE_URL=postgresql://rivr:password@postgres:5432/rivr_person

# Instance identity — defines this as a sovereign person instance.
INSTANCE_TYPE=person
# REQUIRED — Unique UUID for this instance. Generate with: uuidgen
INSTANCE_ID=replace-with-uuid
INSTANCE_SLUG=person
INSTANCE_NAME=Rivr Person
# REQUIRED — UUID of the primary agent/person who owns this instance.
PRIMARY_AGENT_ID=replace-with-person-agent-uuid

# Federation registry — points to the global Rivr instance for
# cross-instance discovery and federation.
REGISTRY_URL=https://app.rivr.social/api/federation/registry
NEXT_PUBLIC_REGISTRY_URL=https://app.rivr.social/api/federation/registry
NEXT_PUBLIC_GLOBAL_URL=https://app.rivr.social

# REQUIRED — Admin key for privileged operations.
# Generate with: openssl rand -hex 32
NODE_ADMIN_KEY=replace-with-admin-key

# REQUIRED — Token for autobot/MCP AI agent access.
# This authenticates OpenClaw against POST /api/mcp.
# Generate with: openssl rand -hex 32
AIAGENT_MCP_TOKEN=replace-with-a-long-random-token

# Memory limit for the rivr-person container
RIVR_MEMORY_LIMIT=1G


# ==============================================================
# OBJECT STORAGE (MinIO)
# ==============================================================
# If you have an external S3/MinIO instance, configure it here.
# Otherwise, you can add a MinIO service to the compose file.

MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
# REQUIRED if using MinIO — Change the default password.
MINIO_SECRET_KEY=replace-with-strong-password
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=replace-with-strong-password
MINIO_BUCKET=rivr-uploads
MINIO_BUCKET_UPLOADS=rivr-uploads
MINIO_BUCKET_AVATARS=rivr-avatars
MINIO_BUCKET_EXPORTS=rivr-exports
ASSET_PUBLIC_BASE_URL=https://s3.example.com
NEXT_PUBLIC_MINIO_URL=https://s3.example.com


# ==============================================================
# OPENCLAW GATEWAY (Agent Runtime)
# ==============================================================

# REQUIRED — Token that secures the OpenClaw gateway API.
# All clients (rivr-person, openclaw-web) use this to authenticate.
# Generate with: openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=replace-with-gateway-token

# Docker image for OpenClaw. Use the official image or build locally.
# To build locally from the Autobot/cartoon/openclaw source:
#   docker build --build-arg OPENCLAW_EXTENSIONS=livekit-avatar -t openclaw:local ./path/to/openclaw
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest

# LLM API keys — at least one is required for the agent to function.
# REQUIRED — Anthropic API key (Claude models).
ANTHROPIC_API_KEY=replace-with-anthropic-api-key
# Optional — OpenAI API key (GPT models, TTS).
OPENAI_API_KEY=

# Agent model configuration
OPENCLAW_MODEL=openclaw/default
OPENCLAW_BACKEND_MODEL=openai/gpt-4o-mini

# Timezone for the agent runtime
TZ=UTC

# Memory limit for the OpenClaw gateway container
OPENCLAW_MEMORY_LIMIT=1G


# ==============================================================
# OPENCLAW WEB (Token Server + Chat UI)
# ==============================================================

# Docker image for the token server. Build from Autobot/token-server:
#   docker build -t openclaw-web:local ./sidecar/openclaw-web
OPENCLAW_WEB_IMAGE=openclaw-web:local
# Path to the openclaw-web build context (token-server + web UI).
# Default assumes sidecar/openclaw-web/ exists. See docs/sovereign-deployment.md.
OPENCLAW_WEB_BUILD_CONTEXT=./sidecar/openclaw-web

# LiveKit configuration — required for real-time voice/avatar features.
# If not using LiveKit, leave these empty; chat still works via HTTP.
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_WS_URL=

# Digital twin worker URL — optional, for avatar/video generation.
# Typically runs on a GPU host (e.g. Vast.ai).
DIGITAL_TWIN_WORKER_URL=

# Optional — Vast.ai API key for GPU voice/avatar workloads.
VAST_API_KEY=


# ==============================================================
# WHISPERX (Speech-to-Text Transcription)
# ==============================================================

# WhisperX model size: tiny, base, small, medium, large-v2, large-v3
WHISPERX_MODEL=base

# Device: cpu or cuda (uncomment GPU section in compose for cuda)
WHISPERX_DEVICE=cpu
WHISPERX_COMPUTE_TYPE=int8
WHISPERX_BATCH_SIZE=16

# HuggingFace token — required for speaker diarization.
# Get one at: https://huggingface.co/settings/tokens
# Must accept pyannote model terms first:
#   https://huggingface.co/pyannote/speaker-diarization-3.1
HF_TOKEN=

# Optional API key to protect the WhisperX endpoint.
WHISPERX_API_KEY=

# Memory limit for the WhisperX container
WHISPERX_MEMORY_LIMIT=2G


# ==============================================================
# OPTIONAL INTEGRATIONS
# ==============================================================

# SMTP for email notifications
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com
SMTP_SECURE=false
SMTP_TLS_REJECT_UNAUTHORIZED=true

# Stripe for payment processing
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Mapbox for map features
MAPBOX_TOKEN=
NEXT_PUBLIC_MAPBOX_TOKEN=

# App release metadata
APP_RELEASE_CHANNEL=stable
APP_UPSTREAM_REPO=rivr-social/rivr-person
